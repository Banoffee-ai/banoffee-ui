{
  "name": "@banoffee-ai/ui",
  "version": "0.1.0",
  "description": "Banoffee.ai design system — shared component library for eClarify, Vidhik, and banoffee.ai. Published via GitHub Packages.",
  "author": "Banoffee.ai",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup && npm run build:types && npm run build:css",
    "build:types": "tsc --project tsconfig.build.json",
    "build:css": "cp src/styles/index.css dist/styles.css",
    "build:sb": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && vitest run",
    "release": "npm run prepublishOnly && npm publish"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Banoffee-ai/banoffee-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Banoffee-ai/banoffee-ui/issues"
  },
  "homepage": "https://github.com/Banoffee-ai/banoffee-ui#readme",
  "keywords": [
    "banoffee",
    "ui",
    "design-system",
    "react",
    "tailwind",
    "component-library"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
