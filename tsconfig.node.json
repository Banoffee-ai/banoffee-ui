{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": [
    "vite.config.ts",
    "tsup.config.ts",
    "vitest.config.ts",
    "tailwind.config.ts"
  ]
}
